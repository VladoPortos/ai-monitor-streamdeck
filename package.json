{
  "name": "ai-monitor-streamdeck",
  "version": "0.1.0",
  "description": "Stream Deck plugin: Anthropic plan usage + service status, account-wide via OAuth, zero per-machine setup.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,html}\" \"tests/**/*.ts\"",
    "pack": "node scripts/pack.mjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('com.vladoportos.aimonitor.sdPlugin/bin',{recursive:true,force:true});\""
  },
  "dependencies": {
    "@elgato/streamdeck": "^1.3.0",
    "@expo-google-fonts/inter": "^0.4.2",
    "satori": "^0.26.0",
    "sharp": "^0.34.0",
    "undici": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.22.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
